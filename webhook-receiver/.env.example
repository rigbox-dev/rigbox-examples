# Template — copy to `.env.production` (or export in your shell) and fill in.
#
# `rig deploy --stage production` loads `.env.production` (then `.env.local`,
# then `.env`) into the deploy env. Only names declared in the manifest's
# `secrets:` are actually sent to the deploy — anything extra here is ignored.
#
# Real secret values belong in `.env.local` (gitignored) or your shell, which
# always win over a committed file. `.env.example` itself is never loaded.

# Shared HMAC key the receiver validates incoming X-Signature headers against.
WEBHOOK_HMAC_KEY=
