# Per-project deploy state, created by `rig deploy`. Records which
# workspace(s) the project is bound to so redeploys target the right one.
.rig.lock

# Legacy per-app / composition lock files (pre-consolidation). No longer
# written, but ignore them defensively — they could contain resolved
# secrets and must never be committed.
.rig-app-deploy.lock
.rig-workspace-deploy.lock

# Node
node_modules/

# Python
__pycache__/
*.pyc
.venv/

# Editor / OS
.DS_Store
.idea/
.vscode/
