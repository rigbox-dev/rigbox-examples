# Per-project deploy state, created by `rig deploy`. Records which
# workspace(s) the project is bound to so redeploys target the right one.
.rig.lock

# Legacy per-app / composition lock files (pre-consolidation). No longer
# written, but ignore them defensively — they could contain resolved
# secrets and must never be committed.
.rig-app-deploy.lock
.rig-workspace-deploy.lock

# Node
node_modules/

# Python
__pycache__/
*.pyc
.venv/

# Local env overrides that hold REAL secret values — never commit these.
# Committed `.env.example` (template) and `.env.<stage>` (demo values) are
# fine; real values go in `.env.local` / `.env.<stage>.local` (highest
# precedence) or your shell, which always win over the committed files.
.env
.env.local
.env.*.local

# Editor / OS
.DS_Store
.idea/
.vscode/
